# Public URL of this app (Shopify Partners App URL, eBay OAuth redirects)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Shopify store
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2025-01

# Partners app (Client ID + Secret)
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=shpss_your_app_secret

# Optional: store custom app Admin API token
# SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_xxxxxxxx

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# App sign-in uses Supabase Auth (email/password).
# Create users in Supabase → Authentication → Users (no public sign-up page).
# Add redirect URLs: http://localhost:3000/auth/callback and your Vercel URL/auth/callback

# Optional but recommended for server-side sync (Settings → API → service_role / secret key)
# Required on Vercel for eBay OAuth token storage
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: default Shopify location ID for stock updates (numeric)
# SHOPIFY_LOCATION_ID=116617511244

# Amazon seller subscription deducted on dashboard (GBP per month, prorated by date range)
# AMAZON_SUBSCRIPTION_MONTHLY=30

# VAT rate added on eBay selling fee, ads fee, and product cost (default 20%)
# PRODUCT_COST_VAT_RATE=0.2

# Flat eBay Final Value Fee per order (GBP)
# EBAY_FINAL_VALUE_FEE=0.10

# eBay Finances API (Sandbox or production)
# EBAY_CLIENT_ID=your_app_id
# EBAY_CLIENT_SECRET=your_cert_id
# EBAY_DEV_ID=your_dev_id
# EBAY_RU_NAME=your_ru_name
# EBAY_ENV=sandbox
# EBAY_MARKETPLACE=EBAY_GB
# EBAY_SELLER_USERNAME=your_ebay_username
# Optional: store refresh token in env instead of data/ebay-oauth.json
# EBAY_REFRESH_TOKEN=
